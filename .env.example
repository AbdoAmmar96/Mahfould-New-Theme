APP_NAME="محفول مكفول"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Cairo
APP_URL=http://localhost:8000
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mahfol_makfol
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@mahfolmakfol.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Paymob (Intention API v1 + Unified Checkout) ──
PAYMOB_BASE_URL=https://accept.paymob.com
PAYMOB_SECRET_KEY=
PAYMOB_API_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_IDS=

# ── بوابة الدفع النشطة ──
PAYMENT_GATEWAY=paymob

# ── Fawry (Express Checkout) ──
FAWRY_BASE_URL=https://atfawry.fawrystaging.com
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=

# ── WhatsApp (إشعارات الحجز) ──
WHATSAPP_DRIVER=log
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE=booking_confirmation
WHATSAPP_TEMPLATE_LANG=ar

# ── إشعارات المتصفح (Web Push / VAPID) ──
# ولّد المفاتيح بـ: php artisan webpush:vapid
# سيبها فاضية والإشعارات هتتعطّل بهدوء من غير ما تكسر أي حاجة.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="${APP_URL}"

VITE_APP_NAME="${APP_NAME}"
