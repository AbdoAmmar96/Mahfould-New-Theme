##############################################
# محفول مكفول — قالب متغيرات البيئة للإنتاج
# انسخ هذا الملف إلى .env على السيرفر واملأ القيم.
##############################################

APP_NAME="محفول مكفول"
APP_ENV=production
APP_KEY=                          # ← ولّده مرة واحدة: php artisan key:generate
APP_DEBUG=false
APP_URL=https://mahfolmakfol.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_EG

##############################################
# قاعدة البيانات — MySQL 8 (لا MariaDB — §0)
##############################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mahfol_prod
DB_USERNAME=                      # ← مستخدم مخصّص للتطبيق (ليس root)
DB_PASSWORD=                      # ← قوي (24+ حرف)
# للاتصال بـSSL على DB مُدارة:
# DB_SSL_MODE=require
# MYSQL_ATTR_SSL_CA=/path/to/ca-cert.pem

##############################################
# Cache/Session/Queue — Redis إلزامي للتزامن العالي (§0)
##############################################
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                   # ← لا تتركه فاضي في الإنتاج
REDIS_CLIENT=phpredis

SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true        # ← إلزامي مع HTTPS

##############################################
# البريد — Postmark/SendGrid/Mailgun
##############################################
MAIL_MAILER=smtp
MAIL_HOST=smtp.postmarkapp.com    # ← أو smtp.sendgrid.net / smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=                    # ← مفتاح API
MAIL_PASSWORD=                    # ← نفس المفتاح عادةً
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@mahfolmakfol.com"
MAIL_FROM_NAME="${APP_NAME}"

##############################################
# Paymob (§5) — بوابة الدفع الأساسية
##############################################
PAYMOB_ENABLED=true
PAYMOB_API_KEY=                   # ← من Paymob Dashboard → Settings → API Keys
PAYMOB_INTEGRATION_ID_CARD=       # ← Integration → Online Card
PAYMOB_INTEGRATION_ID_WALLET=     # ← Integration → Wallet
PAYMOB_IFRAME_ID=                 # ← الـiframe الخاص بحسابك
PAYMOB_HMAC_SECRET=               # ← Settings → HMAC — للتحقق من webhooks
PAYMOB_CURRENCY=EGP

##############################################
# Fawry (§5) — بوابة الدفع البديلة
##############################################
FAWRY_ENABLED=true
FAWRY_MERCHANT_CODE=              # ← من Fawry Business Portal
FAWRY_SECURITY_KEY=               # ← Secret HMAC
FAWRY_BASE_URL=https://www.atfawry.com  # ← أو staging.atfawry.com للاختبار
FAWRY_RETURN_URL=${APP_URL}/payment/fawry/callback

##############################################
# WhatsApp/SMS notifications
##############################################
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

##############################################
# Storage — S3-compatible للأصول (اختياري)
##############################################
FILESYSTEM_DISK=local             # local أو s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=me-south-1
# AWS_BUCKET=
# AWS_URL=https://cdn.mahfolmakfol.com

##############################################
# Logging + Error tracking
##############################################
LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_LEVEL=warning                 # في الإنتاج، warning يمنع تضخم اللوجات
LOG_DAILY_DAYS=14

# Sentry/Bugsnag (اختياري بس مستحسن جداً)
# SENTRY_LARAVEL_DSN=

##############################################
# Security
##############################################
TRUSTED_PROXIES=                  # ← IPs الـload balancer/CDN
# مثلاً لـCloudflare: *
SANCTUM_STATEFUL_DOMAINS=mahfolmakfol.com,www.mahfolmakfol.com

##############################################
# Scheduler + Queue worker
##############################################
# لازم:
# 1) cron واحد كل دقيقة: * * * * * cd /path && php artisan schedule:run
# 2) supervisor worker: php artisan queue:work --sleep=3 --tries=3
